@model IReadOnlyList<SiteCategoryMenuItemViewModel>

<div class="hero-category-menu"
     data-category-mega-root>
    <nav class="hero-cat-sidebar hero-surface"
         aria-label="Danh mục sản phẩm"
         id="hero-cat-sidebar">
        @foreach (var category in Model)
        {
            var megaPanelId = $"home-{category.Id}-mega";
            var labelId = $"home-{category.Id}-menu-label";
            IReadOnlyList<SiteCategoryMenuLinkViewModel> categoryLinks = category.CategoryLinks.Count > 0
                ? category.CategoryLinks
                : new[]
                {
                    new SiteCategoryMenuLinkViewModel
                    {
                        Label = category.Label,
                        Url = category.Url
                    }
                };
            var isSplitItem = categoryLinks.Count > 1;

            <div class="hero-cat-entry"
                 data-category-entry
                 data-category-mega-panel-id="@megaPanelId">
                @if (isSplitItem)
                {
                    <div class="hero-cat-item hero-cat-item--split"
                         role="group"
                         tabindex="-1"
                         aria-label="@category.Label"
                         aria-haspopup="true"
                         aria-expanded="false"
                         aria-controls="@megaPanelId"
                         data-category-link>
                        <svg class="hero-ui-icon hero-cat-icon" aria-hidden="true">
                            <use href="@($"#hero-icon-{category.Icon}")"></use>
                        </svg>
                        <span class="hero-cat-label" id="@labelId">
                            @foreach (var categoryLink in categoryLinks)
                            {
                                <a class="hero-cat-label-part hero-cat-label-link"
                                   href="@categoryLink.Url">@categoryLink.Label</a>
                            }
                        </span>
                        <svg class="hero-ui-icon hero-cat-arrow" aria-hidden="true">
                            <use href="#hero-icon-chevron"></use>
                        </svg>
                    </div>
                }
                else
                {
                    var categoryLink = categoryLinks[0];

                    <a class="hero-cat-item"
                       href="@categoryLink.Url"
                       aria-label="@category.Label"
                       aria-haspopup="true"
                       aria-expanded="false"
                       aria-controls="@megaPanelId"
                       data-category-link>
                        <svg class="hero-ui-icon hero-cat-icon" aria-hidden="true">
                            <use href="@($"#hero-icon-{category.Icon}")"></use>
                        </svg>
                        <span class="hero-cat-label" id="@labelId">
                            <span class="hero-cat-label-part">@categoryLink.Label</span>
                        </span>
                        <svg class="hero-ui-icon hero-cat-arrow" aria-hidden="true">
                            <use href="#hero-icon-chevron"></use>
                        </svg>
                    </a>
                }
            </div>
        }
    </nav>

    <partial name="~/Views/Shared/Partials/_CategoryMegaPanels.cshtml"
             model="@(new SiteCategoryMegaPanelsViewModel
             {
                 IdPrefix = "home",
                 StageClass = "hero-category-mega-stage",
                 Items = Model
             })" />
</div>
